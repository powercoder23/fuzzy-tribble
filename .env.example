DHAN_CLIENT_ID=your_client_id
DHAN_ACCESS_TOKEN=your_access_token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
# Optional Discord fallback: alerts go here only when Telegram fails or is unset.
# Create one via Discord → Channel Settings → Integrations → Webhooks.
DISCORD_WEBHOOK_URL=
# Set to 1/true to skip Telegram and send alerts only to Discord.
ALERTS_DISCORD_ONLY=
# OI-contradiction auto-exit: off (default) | soft (log only) | hard (close now).
# Closes an open paper position when a strong opposite-side OI buildup appears.
AUTO_EXIT_OI_MODE=hard
AUTO_EXIT_OI_MIN_OI_CHG_PCT=2.0
AUTO_EXIT_OI_REQUIRE_STRONG=false
AUTO_EXIT_OI_MAX_PROFIT_PCT=10
# Market & sector breadth filter: off (default) | soft (log only) | hard (block).
# Blocks fresh CE into a broadly-red tape/sector and PE into a broadly-green one.
BREADTH_GATE_MODE=off
BREADTH_MIN_FOR_CE=35
BREADTH_MAX_FOR_PE=65
BREADTH_SECTOR_ENABLED=true
BREADTH_SECTOR_MIN_FOR_CE=40
BREADTH_SECTOR_MAX_FOR_PE=60
# Morning sector heatmap alert time (discount scheduler).
SECTOR_HEATMAP_AT=09:50

# After a strategy (e.g. Break & Bounce) confirms a direction, let the DISCOUNT
# scanner pick the cheapest / best-value strike on that underlying and trade it
# instead of the strategy's own ATM+offset. Default OFF (strategy uses its own
# strike). off/false | true.
STRATEGY_STRIKE_VIA_DISCOUNT=false
# OI-buildup / Sonar-Laplace: scanning + DB persistence always run. These only
# control whether each one's Telegram alert is pushed externally; default is
# internal-use-only (false).
OIB_ALERTS_ENABLED=false
SONAR_ALERTS_ENABLED=false
# ── Convex Engine (V2 P0, observe-only) ──────────────────────────────────────
